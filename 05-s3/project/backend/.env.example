# Copy to .env and fill in. Secure it:  chmod 600 .env
PORT=5000
AWS_REGION=ap-south-1
S3_BUCKET=yourname-secure-uploads-xxxx

# LOCAL DEV ONLY — on EC2/Lambda use an IAM ROLE instead of these keys:
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# Upload constraints (validated server-side before signing)
MAX_UPLOAD_MB=10
ALLOWED_TYPES=image/png,image/jpeg,application/pdf
ALLOWED_ORIGIN=http://localhost:5173
